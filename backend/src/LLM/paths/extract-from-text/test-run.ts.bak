import { chunkText, extractFromText } from "./indext.js";

const sampleText = ``;

const result = await extractFromText({
  chunks: chunkText(sampleText),
  extractionTags: [
    [
      "characters",
      "a named individual person, being, or entity — NOT collective nouns like 'demons', 'angels', 'Succubi'",
    ],
    ["location", "a location in the story"],
    [
      "items",
      "a distinct physical object a character can hold, carry, or interact with — NOT body parts, NOT locations, NOT abstract concepts, NOT groups of people",
    ],
  ],
});

console.log(JSON.stringify(result, null, 2));
